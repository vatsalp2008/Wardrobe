<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Copy this file to `Config.plist` (gitignored) and fill in real values.
  Keys left empty cause the app to run on MOCK services (the Phase 0/early-dev default).
  See SETUP.md §"API Keys" for where to obtain each value.

  Note: ANTHROPIC_API_KEY, REPLICATE_API_TOKEN, SERPAPI_KEY and REMOVE_BG_KEY can
  alternatively be supplied via Xcode scheme Environment Variables instead of this file.
-->
<plist version="1.0">
<dict>
    <key>ANTHROPIC_API_KEY</key>
    <string></string>

    <!-- Alternative AI provider. If set, Gemini is used instead of Claude. -->
    <key>GEMINI_API_KEY</key>
    <string></string>

    <key>REPLICATE_API_TOKEN</key>
    <string></string>

    <key>SUPABASE_URL</key>
    <string></string>

    <key>SUPABASE_ANON_KEY</key>
    <string></string>

    <key>SERPAPI_KEY</key>
    <string></string>

    <key>REMOVE_BG_KEY</key>
    <string></string>

    <!-- Optional dev-only fallback when WeatherKit entitlement is unavailable -->
    <key>OPENWEATHERMAP_KEY</key>
    <string></string>
</dict>
</plist>
